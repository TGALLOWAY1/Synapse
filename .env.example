# Synapse environment variables
#
# These configure the *recruiter-portal backend* (the Vercel serverless
# functions under `api/`). The PRD workspace — the main Synapse product — is
# 100% client-side and needs NONE of these: its Gemini API key and model
# selection are entered in the in-app Settings dialog and stored in
# localStorage, never in a .env file.
#
# Copy to `.env` for local backend development. All values below are required
# only for the feature that uses them (see comments). Omit an OAuth provider's
# vars to disable that provider.

# --- Sessions (required for any authenticated backend route) ---------------
# Random secret used to HMAC-sign session cookies. Use >= 32 random chars.
SESSION_SECRET=

# --- MongoDB Atlas Data API (required for the recruiter portal) ------------
MONGODB_DATA_API_URL=
MONGODB_DATA_API_KEY=
MONGODB_DATA_SOURCE=
MONGODB_DB_NAME=synapse

# --- OAuth providers (optional; configure the ones you want enabled) -------
# Redirect URIs default to `${baseUrl}/api/auth/<provider>/callback` when unset.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# --- Owner-only cloud snapshots (SnapshotsPanel) ---------------------------
# SYNAPSE_OWNER_TOKEN gates snapshot save/load/delete; use >= 24 random chars.
# BLOB_READ_WRITE_TOKEN is auto-provisioned by Vercel Blob in production.
SYNAPSE_OWNER_TOKEN=
BLOB_READ_WRITE_TOKEN=

# --- Admin dashboard -------------------------------------------------------
# Gates GET /api/admin/recruiters.
ADMIN_DASHBOARD_KEY=

# NODE_ENV is set by the platform (development | production); in production it
# makes session cookies Secure. You normally do not set this by hand.
