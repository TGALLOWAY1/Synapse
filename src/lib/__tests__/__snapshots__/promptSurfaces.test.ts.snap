    "Patient notes must remain private."
  ],
  "safetyBoundaries": [
    "Do not provide autonomous diagnosis."
  ],
  "availableArtifacts": [
    "data_model",
    "screen_inventory"
  ],
  "missingArtifacts": [
    "user_flows",
    "implementation_plan",
    "design_system"
  ],
  "inScopeSourceKeys": [
